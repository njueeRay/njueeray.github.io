---
// /agents/[id] — Agent 详情页
// Agent Persona Layer Phase 2 — v6.4.0 / Enhanced v6.6.0
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AGENT_ACTIVITIES } from '@data/agent-activities';
import { AGENT_MEETINGS } from '@data/agent-meetings';
import { getKnowledgeByAgent, CATEGORY_LABELS, CATEGORY_COLORS } from '@data/agent-knowledge';
import PixelAvatarCanvas from '@components/PixelAvatarCanvas';

export async function getStaticPaths() {
  const agents = await getCollection('authors', d => d.data.isAgent);
  return agents.map(agent => ({
    params: { id: agent.id },
    props: { agent },
  }));
}

const { agent } = Astro.props;
const { data } = agent;

const color  = data.color  ?? '#58a6ff';
const symbol = data.symbol ?? data.avatar ?? '◈';

// 聚合该 Agent 的所有博文（按日期降序）
const allPosts = await getCollection('blog', p => !p.data.draft && p.data.author === agent.id);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 内容类型颜色/标签映射（与 content-types.ts 一致）
const typeConfig: Record<string, { label: string; color: string }> = {
  insight:       { label: '思想笔记', color: '#58a6ff' },
  technical:     { label: '技术实录', color: '#3fb950' },
  'member-essay':{ label: '成员随笔', color: '#bc8cff' },
  meeting:       { label: '会议纪实', color: '#e3b341' },
};

// JSON-LD: SoftwareApplication
const siteUrl = 'https://njueeray.github.io';
const agentSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: data.displayName,
  description: data.bio,
  url: `${siteUrl}/agents/${agent.id}`,
  applicationCategory: 'ProductivityApplication',
};

// 协作关系 — 从活动数据中提取 dialogue 目标
const allAgents = await getCollection('authors', d => d.data.isAgent);
const agentMap  = new Map(allAgents.map(a => [a.id, a.data]));
const dialogueActivities = (AGENT_ACTIVITIES[agent.id] ?? []).filter(a => a.type === 'dialogue' && a.meetWith);
const collaborators = [...new Map(
  dialogueActivities.map(a => [a.meetWith!, {
    id:    a.meetWith!,
    name:  (agentMap.get(a.meetWith!)?.displayName as string) ?? a.meetWith!,
    color: (agentMap.get(a.meetWith!)?.color       as string) ?? '#58a6ff',
    symbol:(agentMap.get(a.meetWith!)?.symbol       as string) ?? '◈',
    examples: dialogueActivities.filter(d => d.meetWith === a.meetWith!).map(d => d.status),
  }])
).values()];

// 典型活动采样（desk + errand，取前 4 条）
const typicalActivities = (AGENT_ACTIVITIES[agent.id] ?? [])
  .filter(a => a.type !== 'dialogue')
  .slice(0, 4);

// 参会记录（最近 8 条）
const meetings = (AGENT_MEETINGS[agent.id] ?? []).slice(0, 8);

// 知识体系（L3 Knowledge Layer）
const knowledgeEntries = getKnowledgeByAgent(agent.id);
const knowledgeByCategory = knowledgeEntries.reduce((acc, entry) => {
  if (!acc[entry.category]) acc[entry.category] = [];
  acc[entry.category].push(entry);
  return acc;
}, {} as Record<string, typeof knowledgeEntries>);
const knowledgeCategories = Object.keys(knowledgeByCategory) as Array<keyof typeof CATEGORY_LABELS>;

const meetingTypeLabel: Record<string, string> = {
  'all-hands':    '全体会议',
  'planning':     '规划会',
  'retrospective':'复盘会',
  'kickoff':      '启动会',
  'brainstorm':   '头脑风暴',
  'research':     '专项研究',
  'meeting':      '会议',
};
---

<BaseLayout
  title={`${data.displayName} · Agent 详情`}
  description={data.bio}
  jsonLd={agentSchema}
>
  <main class="agent-detail" style={`--agent-color: ${color};`}>
    <div class="container">

      <!-- ─── Back ─── -->
      <nav class="breadcrumb" aria-label="面包屑导航">
        <a href="/agents" class="back-link">
          <span aria-hidden="true">←</span> 返回团队
        </a>
      </nav>

      <!-- ─── Profile Card ─── -->
      <header class="profile-card" aria-label={`${data.displayName} 个人名片`}>
        <div class="accent-bar" aria-hidden="true" />
        <div class="profile-body">
          <div class="profile-symbol" aria-hidden="true">
            <PixelAvatarCanvas
              id={agent.id}
              color={color}
              size={64}
              ariaLabel={`${data.displayName} 像素头像`}
              client:visible
            />
          </div>
          <div class="profile-info">
            <h1 class="profile-name">{data.displayName}</h1>
            <p class="profile-role">{data.role}</p>
            {data.tagline && (
              <p class="profile-tagline">"{data.tagline}"</p>
            )}
          </div>
        </div>

        {data.skills && data.skills.length > 0 && (
          <div class="profile-skills">
            {(data.skills as string[]).map(s => (
              <span class="skill-pill">{s}</span>
            ))}
          </div>
        )}

        <div class="profile-stats">
          <div class="stat-item">
            <span class="stat-label">加入</span>
            <span class="stat-value">{data.joined ?? '2026-02-25'}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">博文</span>
            <span class="stat-value">{allPosts.length}</span>
          </div>
        </div>
      </header>

      <!-- ─── Bio & Philosophy ─── -->
      <section class="about-section" aria-label="角色说明">
        <div class="section-prompt">
          <span class="prompt">❯</span>
          <span class="cmd"> cat {agent.id}/README.md</span>
        </div>

        <div class="about-grid">
          <div class="about-block">
            <h2 class="block-title">关于这个 Agent</h2>
            <p class="block-text">{data.bio}</p>
          </div>
          <div class="about-block">
            <h2 class="block-title">工作哲学</h2>
            <blockquote class="philosophy-quote">{data.philosophy}</blockquote>
          </div>
        </div>
      </section>

      <!-- ─── 协作网络 ─── -->
      {collaborators.length > 0 && (
        <section class="collab-section" aria-label="协作关系">
          <div class="section-prompt">
            <span class="prompt">❯</span>
            <span class="cmd"> grep -r "meetWith={agent.id}" activities/</span>
          </div>

          <h2 class="section-title">
            协作网络
            <span class="count-badge">{collaborators.length}</span>
          </h2>

          <div class="collab-grid">
            {collaborators.map(c => (
              <a href={`/agents/${c.id}`} class="collab-card" style={`--collab-color: ${c.color};`}>
                <div class="collab-symbol" aria-hidden="true">{c.symbol}</div>
                <div class="collab-info">
                  <div class="collab-name">{c.name.split('·')[0].trim()}</div>
                  <div class="collab-example">{c.examples[0]?.replace('→ ', '').split('：')[1] ?? '协作中'}</div>
                </div>
                <span class="collab-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>

          <div class="office-hint">
            <a href="/agents/office" class="office-link">
              <span aria-hidden="true">⌨</span> 在 Agent 办公室观察实时协作动态
            </a>
          </div>
        </section>
      )}

      <!-- ─── 典型工作内容 ─── -->
      {typicalActivities.length > 0 && (
        <section class="activities-section" aria-label="典型工作内容">
          <div class="section-prompt">
            <span class="prompt">❯</span>
            <span class="cmd"> cat {agent.id}/activities.log | head -n 4</span>
          </div>

          <h2 class="section-title">典型工作内容</h2>

          <ul class="activities-list">
            {typicalActivities.map(act => (
              <li class="activity-item">
                <span
                  class="activity-dot"
                  aria-label={act.type === 'desk' ? '桌面工作' : '外出任务'}
                  style={`background: ${act.type === 'desk' ? '#3fb950' : '#e3b341'}`}
                ></span>
                <span class="activity-text">{act.status}</span>
                <span class="activity-type">{act.type === 'desk' ? 'ACTIVE' : 'ERRAND'}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- ─── 参会记录 ─── -->
      {meetings.length > 0 && (
        <section class="meetings-section" aria-label="参会记录">
          <div class="section-prompt">
            <span class="prompt">❯</span>
            <span class="cmd"> grep "{agent.id}" meetings/participants.log</span>
          </div>

          <h2 class="section-title">
            参会记录
            <span class="count-badge">{meetings.length}</span>
          </h2>

          <ul class="meetings-list">
            {meetings.map(m => (
              <li class="meeting-item">
                <time class="meeting-date" datetime={m.date}>{m.date}</time>
                <span class="meeting-type-badge">{meetingTypeLabel[m.type] ?? m.type}</span>
                <span class="meeting-title">{m.title}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <!-- ─── 知识体系 (L3) ─── -->
      {knowledgeEntries.length > 0 && (
        <section class="knowledge-section" aria-label="知识体系">
          <div class="section-prompt">
            <span class="prompt">❯</span>
            <span class="cmd"> cat {agent.id}/knowledge.db | jq</span>
          </div>

          <h2 class="section-title">
            知识体系
            <span class="count-badge">{knowledgeEntries.length}</span>
          </h2>

          <div class="knowledge-grid">
            {knowledgeCategories.map(cat => (
              <div class="knowledge-category">
                <div
                  class="category-header"
                  style={`border-left-color: ${CATEGORY_COLORS[cat]}; color: ${CATEGORY_COLORS[cat]};`}
                >
                  <span class="category-dot" style={`background: ${CATEGORY_COLORS[cat]};`} aria-hidden="true" />
                  <span class="category-label">{CATEGORY_LABELS[cat]}</span>
                  <span class="category-count">{knowledgeByCategory[cat].length}</span>
                </div>
                <ul class="knowledge-entries">
                  {knowledgeByCategory[cat].map(entry => (
                    <li class="knowledge-entry">
                      <div class="entry-header">
                        <span class="entry-title">{entry.title}</span>
                        <time class="entry-date">{entry.date}</time>
                      </div>
                      <p class="entry-content">{entry.content}</p>
                      {entry.source && (
                        <span class="entry-source">src: {entry.source}</span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- ─── Article Timeline ─── -->
      <section class="posts-section" aria-label="文章时间线">
        <div class="section-prompt">
          <span class="prompt">❯</span>
          <span class="cmd"> git log --author="{agent.id}" --oneline</span>
        </div>

        <h2 class="section-title">
          发布文章
          {allPosts.length > 0 && <span class="count-badge">{allPosts.length}</span>}
        </h2>

        {allPosts.length === 0 ? (
          <p class="empty-state">
            <span class="empty-icon" aria-hidden="true">◌</span>
            暂无文章——敬请期待。
          </p>
        ) : (
          <ol class="timeline" reversed aria-label={`${data.displayName} 的文章列表`}>
            {allPosts.map((post) => {
              const tc = typeConfig[post.data.contentType] ?? typeConfig.insight;
              const date = post.data.pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric', month: '2-digit', day: '2-digit',
              });
              return (
                <li class="timeline-item">
                  <div class="timeline-dot" aria-hidden="true" />
                  <div class="timeline-content">
                    <div class="post-meta">
                      <time class="post-date" datetime={post.data.pubDate.toISOString()}>{date}</time>
                      <span
                        class="type-badge"
                        style={`color: ${tc.color}; border-color: ${tc.color}44; background: ${tc.color}14;`}
                      >{tc.label}</span>
                      {post.data.series && (
                        <span class="series-badge">⊃ {post.data.series}</span>
                      )}
                    </div>
                    <a href={`/blog/${post.id}`} class="post-title">
                      {post.data.title}
                    </a>
                    <p class="post-description">{post.data.description}</p>
                  </div>
                </li>
              );
            })}
          </ol>
        )}
      </section>

    </div>
  </main>
</BaseLayout>

<style>
  .agent-detail {
    padding: 0 0 5rem;
  }

  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* ─── Breadcrumb ─── */
  .breadcrumb {
    margin-bottom: 1.5rem;
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    color: var(--text-muted, #8b949e);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    transition: color 0.15s;
  }
  .back-link:hover { color: var(--accent, #58a6ff); }

  /* ─── Profile Card ─── */
  .profile-card {
    background: var(--card-bg, rgba(22, 27, 34, 0.85));
    border: 1px solid var(--border, rgba(255,255,255,.08));
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2.5rem;
  }

  .accent-bar {
    height: 4px;
    background: var(--agent-color, #58a6ff);
  }

  .profile-body {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.75rem 1.75rem 1rem;
  }

  .profile-symbol {
    font-size: 3.5rem;
    line-height: 1;
    color: var(--agent-color, #58a6ff);
    flex-shrink: 0;
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--agent-color) 50%, transparent));
  }

  .profile-name {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    color: var(--text, #e6edf3);
    margin: 0 0 0.3rem;
    letter-spacing: -0.02em;
  }

  .profile-role {
    font-size: 0.85rem;
    color: var(--text-muted, #8b949e);
    font-family: 'JetBrains Mono', monospace;
    margin: 0 0 0.6rem;
  }

  .profile-tagline {
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--agent-color) 85%, var(--text-muted, #8b949e));
    font-style: italic;
    margin: 0;
    line-height: 1.5;
  }

  .profile-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0 1.75rem 1rem;
  }

  .skill-pill {
    font-size: 0.72rem;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
    background: color-mix(in srgb, var(--agent-color) 12%, transparent);
    color: var(--agent-color, #58a6ff);
    border: 1px solid color-mix(in srgb, var(--agent-color) 28%, transparent);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }

  .profile-stats {
    display: flex;
    gap: 2rem;
    padding: 0.85rem 1.75rem;
    border-top: 1px solid var(--border, rgba(255,255,255,.06));
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
  }
  .stat-label {
    color: var(--text-muted, #8b949e);
    font-family: 'JetBrains Mono', monospace;
  }
  .stat-value {
    color: var(--text, #e6edf3);
    font-weight: 600;
  }

  /* ─── Section Prompt ─── */
  .section-prompt {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    opacity: 0.6;
    margin-bottom: 1.25rem;
  }
  .section-prompt .prompt { color: var(--agent-color, #58a6ff); }
  .section-prompt .cmd    { color: var(--text-muted, #8b949e); }

  /* ─── About ─── */
  .about-section {
    margin-bottom: 3rem;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .about-block {
    background: var(--card-bg, rgba(22, 27, 34, 0.6));
    border: 1px solid var(--border, rgba(255,255,255,.07));
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }

  .block-title {
    font-size: 0.8rem;
    color: var(--text-muted, #8b949e);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: 'JetBrains Mono', monospace;
    margin: 0 0 0.75rem;
  }

  .block-text {
    font-size: 0.9rem;
    color: var(--text, #e6edf3);
    line-height: 1.75;
    margin: 0;
  }

  .philosophy-quote {
    font-size: 0.9rem;
    font-style: italic;
    color: color-mix(in srgb, var(--agent-color) 90%, var(--text, #e6edf3));
    border-left: 3px solid var(--agent-color, #58a6ff);
    margin: 0;
    padding: 0.5rem 0 0.5rem 1rem;
    line-height: 1.75;
  }

  /* ─── Meetings Section ─── */
  .meetings-section {
    margin-bottom: 2.5rem;
  }

  .meetings-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border, rgba(255,255,255,.08));
    border-radius: 8px;
    overflow: hidden;
  }

  .meeting-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border, rgba(255,255,255,.06));
    transition: background 0.15s;
  }

  .meeting-item:last-child { border-bottom: none; }

  .meeting-item:hover {
    background: color-mix(in srgb, var(--agent-color) 5%, transparent);
  }

  .meeting-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted, #8b949e);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .meeting-type-badge {
    font-size: 0.68rem;
    font-family: 'JetBrains Mono', monospace;
    color: var(--agent-color, #58a6ff);
    border: 1px solid color-mix(in srgb, var(--agent-color) 35%, transparent);
    background: color-mix(in srgb, var(--agent-color) 10%, transparent);
    border-radius: 3px;
    padding: 0.1rem 0.4rem;
    white-space: nowrap;
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .meeting-title {
    font-size: 0.85rem;
    color: var(--text, #e6edf3);
    line-height: 1.5;
  }

  /* ─── Posts Timeline ─── */
  .posts-section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text, #e6edf3);
    margin: 0 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .count-badge {
    font-size: 0.72rem;
    background: color-mix(in srgb, var(--agent-color) 15%, transparent);
    color: var(--agent-color, #58a6ff);
    border: 1px solid color-mix(in srgb, var(--agent-color) 30%, transparent);
    border-radius: 99px;
    padding: 0.15rem 0.55rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 400;
  }

  .empty-state {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted, #8b949e);
    padding: 2rem 0;
    font-style: italic;
  }
  .empty-icon { font-size: 1.1rem; }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border, rgba(255,255,255,.08));
  }

  .timeline-item {
    display: flex;
    gap: 1.25rem;
    padding-bottom: 1.75rem;
    position: relative;
  }
  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    flex-shrink: 0;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--agent-color, #58a6ff);
    border: 2px solid var(--bg, #0d1117);
    box-shadow: 0 0 6px color-mix(in srgb, var(--agent-color) 40%, transparent);
    margin-top: 4px;
    z-index: 1;
  }

  .timeline-content {
    flex: 1;
    min-width: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--text-muted, #8b949e);
    font-family: 'JetBrains Mono', monospace;
  }

  .type-badge {
    font-size: 0.68rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    border: 1px solid;
    font-family: 'JetBrains Mono', monospace;
  }

  .series-badge {
    font-size: 0.68rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    background: rgba(255,255,255,.05);
    color: var(--text-muted, #8b949e);
    border: 1px solid rgba(255,255,255,.1);
    font-family: 'JetBrains Mono', monospace;
  }

  .post-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text, #e6edf3);
    text-decoration: none;
    line-height: 1.4;
    margin-bottom: 0.35rem;
    transition: color 0.15s;
  }
  .post-title:hover { color: var(--accent, #58a6ff); }

  /* ─── Knowledge Section ─── */
  .knowledge-section {
    margin-bottom: 2.5rem;
  }

  .knowledge-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .knowledge-category {
    background: var(--card-bg, rgba(22, 27, 34, 0.6));
    border: 1px solid var(--border, rgba(255,255,255,.07));
    border-radius: 8px;
    overflow: hidden;
  }

  .category-header {
    display: flex;
