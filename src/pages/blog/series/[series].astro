---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Build a map of series → posts
  const seriesMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    const s = post.data.series;
    if (!s) continue;
    if (!seriesMap.has(s)) seriesMap.set(s, []);
    seriesMap.get(s)!.push(post);
  }

  return [...seriesMap.entries()].map(([name, posts]) => ({
    params: { series: encodeURIComponent(name) },
    props: {
      seriesName: name,
      posts: posts.sort(
        (a, b) => (a.data.seriesOrder ?? 99) - (b.data.seriesOrder ?? 99)
      ),
    },
  }));
}

interface Props {
  seriesName: string;
  posts: Awaited<ReturnType<typeof getCollection<'blog'>>>;
}

const { seriesName, posts } = Astro.props;
---

<BaseLayout
  title={`${seriesName} — njueeray`}
  description={`系列《${seriesName}》共 ${posts.length} 篇，按顺序深度阅读。`}
>
  <main id="main-content" class="series-page">
    <header class="series-header">
      <p class="series-breadcrumb">
        <a href="/blog">博客</a>
        <span class="sep">›</span>
        <a href="/blog/series">系列</a>
        <span class="sep">›</span>
        <span>{seriesName}</span>
      </p>
      <h1 class="series-title">
        <span class="prompt">❯</span> {seriesName}
      </h1>
      <p class="series-meta">{posts.length} 篇 · 建议按顺序阅读</p>
    </header>

    <ol class="posts-list">
      {posts.map((post, i) => (
        <li class="post-item">
          <span class="post-order">{i + 1}</span>
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-card-main">
              <span class="post-title">{post.data.title}</span>
              <span class="post-desc">{post.data.description}</span>
            </div>
            <div class="post-card-meta">
              <span class="post-date">
                {post.data.pubDate.toLocaleDateString('zh-CN', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
              <span class="post-tags">
                {post.data.tags.slice(0, 2).map(tag => (
                  <a href={`/blog/tags/${tag}`} class="post-tag">{tag}</a>
                ))}
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <footer class="series-footer">
      <a href="/blog/series" class="back-link">← 全部系列</a>
    </footer>
  </main>
</BaseLayout>

<style>
  .series-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    color: var(--color-text-primary, #e6edf3);
  }

  .series-header { margin-bottom: 2.5rem; }

  .series-breadcrumb {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
    color: var(--color-text-muted, #8b949e);
    margin-bottom: 0.75rem;
  }

  .series-breadcrumb a {
    color: var(--color-accent, #58a6ff);
    text-decoration: none;
  }

  .series-breadcrumb a:hover { text-decoration: underline; }

  .sep { margin: 0 0.35rem; opacity: 0.5; }

  .series-title {
    font-family: var(--font-mono, monospace);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-primary, #e6edf3);
    margin: 0 0 0.4rem;
  }

  .prompt { color: var(--color-green, #3fb950); margin-right: 0.5rem; }

  .series-meta {
    font-family: var(--font-mono, monospace);
    font-size: 0.8rem;
    color: var(--color-text-muted, #8b949e);
    margin: 0;
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    counter-reset: series-counter;
  }

  .post-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .post-order {
    font-family: var(--font-mono, monospace);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-accent, #58a6ff);
    min-width: 1.8rem;
    text-align: right;
    padding-top: 0.9rem;
  }

  .post-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border: 1px solid var(--color-border, #21262d);
    border-radius: 8px;
    background: var(--color-surface, #161b22);
    padding: 0.9rem 1.1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.15s;
  }

  .post-card:hover {
    border-color: var(--color-accent, #58a6ff);
    transform: translateX(3px);
  }

  .post-card-main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-primary, #e6edf3);
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary, #8b949e);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.15rem;
  }

  .post-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.73rem;
    color: var(--color-text-muted, #6e7681);
  }

  .post-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    color: var(--color-green, #3fb950);
    background: rgba(63, 185, 80, 0.08);
    border: 1px solid rgba(63, 185, 80, 0.2);
    border-radius: 3px;
    padding: 0.05rem 0.4rem;
    text-decoration: none;
  }

  .post-tag:hover { background: rgba(63, 185, 80, 0.15); }

  .series-footer {
    margin-top: 3rem;
    border-top: 1px solid var(--color-border, #21262d);
    padding-top: 1.5rem;
  }

  .back-link {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    color: var(--color-accent, #58a6ff);
    text-decoration: none;
  }

  .back-link:hover { text-decoration: underline; }

  @media (max-width: 600px) {
    .series-page { padding: 1.5rem 1rem 3rem; }
    .post-item { gap: 0.5rem; }
    .post-order { font-size: 0.9rem; min-width: 1.4rem; }
  }
</style>
