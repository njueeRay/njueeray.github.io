---
// Featured projects section — GitHub API dynamic data at build time (H-2 v5.10.0)
interface RepoMeta { id: string; desc: string; tags: string[] }

const repoMeta: RepoMeta[] = [
  {
    id: 'njueeRay/OpenProfile',
    desc: 'Build your GitHub profile with an AI Agent team — designer, writer, researcher, reviewer in one workflow.',
    tags: ['AI-Native', 'GitHub Copilot', 'Open Source'],
  },
  {
    id: 'njueeRay/wechat_article_exporter',
    desc: 'Export WeChat public account articles to structured formats — built for knowledge archiving and RAG pipelines.',
    tags: ['Python', 'RAG', 'Knowledge Engineering'],
  },
];

interface GitHubRepo { name: string; stargazers_count: number; forks_count: number; pushed_at: string }

const fetchRepo = async (id: string): Promise<GitHubRepo | null> => {
  try {
    const r = await fetch(`https://api.github.com/repos/${id}`, {
      headers: { Accept: 'application/vnd.github.v3+json', 'User-Agent': 'njueeray-site/astro' },
    });
    if (!r.ok) return null;
    return (await r.json()) as GitHubRepo;
  } catch { return null; }
};

const liveData = await Promise.all(repoMeta.map(m => fetchRepo(m.id)));

const projects = repoMeta.map((meta, i) => {
  const live = liveData[i];
  const daysSince = live ? Math.floor((Date.now() - new Date(live.pushed_at).getTime()) / 86_400_000) : null;
  const activeLabel = daysSince === null ? null : daysSince < 7 ? 'Active' : daysSince < 30 ? `${daysSince}d ago` : null;
  return {
    name: live?.name ?? meta.id.split('/')[1],
    desc: meta.desc,
    url: `https://github.com/${meta.id}`,
    tags: meta.tags,
    stars: live?.stargazers_count ?? null,
    forks: live?.forks_count ?? null,
    activeLabel,
  };
});
---

<section class="projects" id="projects">
  <div class="container">
    <h2 class="section-title"><span class="prompt">$</span> ls projects/ --sort=stars</h2>
    <div class="grid">
      {projects.map(p => (
        <a href={p.url} target="_blank" rel="noopener" class="card">
          <div class="card-header">
            <span class="repo-icon">📦</span>
            <span class="name">{p.name}</span>
            {p.activeLabel && <span class="active-badge">{p.activeLabel}</span>}
          </div>
          <p class="desc">{p.desc}</p>
          <div class="card-footer">
            <div class="tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            {(p.stars !== null || p.forks !== null) && (
              <div class="repo-stats">
                {p.stars !== null && <span>⭐ {p.stars}</span>}
                {p.forks !== null && <span>🍴 {p.forks}</span>}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects { padding: 4rem 1.5rem; border-top: 1px solid var(--color-border); }
  .container { max-width: 780px; margin: 0 auto; }
  .section-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .section-title .prompt { color: var(--color-green); margin-right: 0.3rem; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
  .card {
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .card:hover { border-color: var(--color-accent); transform: translateY(-2px); color: inherit; }

  .card-header { display: flex; align-items: center; gap: 0.6rem; }
  .repo-icon { font-size: 1rem; }
  .name { font-family: var(--font-mono); font-weight: 700; color: var(--color-accent); font-size: 0.95rem; }
  .desc { color: var(--color-text-muted); font-size: 0.85rem; line-height: 1.5; flex: 1; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: var(--color-bg-3);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.5rem;
    color: var(--color-text-muted);
  }
  .tag.fork {
    border-color: var(--color-yellow);
    color: var(--color-yellow);
    background: rgba(227, 179, 65, 0.08);
  }
  .card-footer { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.4rem; margin-top: auto; }
  .repo-stats { display: flex; gap: 0.75rem; font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-text-muted); flex-shrink: 0; }
  .active-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-sm, 4px);
    background: rgba(63, 185, 80, 0.12);
    border: 1px solid rgba(63, 185, 80, 0.35);
    color: var(--color-green);
    margin-left: auto;
  }
</style>
