---
// Footer: terminal echo style
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <nav class="footer-nav" aria-label="站内导航">
      <div class="footer-nav-group">
        <span class="nav-group-label">Pages</span>
        <a href="/">home</a>
        <a href="/blog">blog</a>
        <a href="/team">team</a>
      </div>
      <div class="footer-nav-group">
        <span class="nav-group-label">AI-Native</span>
        <a href="/agents">agents</a>
        <a href="/agents/office">office</a>
        <a href="/how-we-work">workflow</a>
      </div>
      <div class="footer-nav-group">
        <span class="nav-group-label">Open Source</span>
        <a href="https://github.com/njueeRay/OpenProfile" target="_blank" rel="noopener">OpenProfile ↗</a>
        <a href="https://github.com/njueeRay/njueeray.github.io" target="_blank" rel="noopener">Site Repo ↗</a>
        <a href="/rss.xml" target="_blank" rel="noopener">RSS</a>
      </div>
    </nav>
    <div class="footer-divider" aria-hidden="true"></div>
    <div class="line">
      <span class="prompt">❯</span>
      <span class="cmd"> echo $FOOTER</span>
    </div>
    <div class="line output">
      <span class="muted">Built with </span>
      <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      <span class="muted"> · Deployed on </span>
      <a href="https://pages.github.com" target="_blank" rel="noopener">GitHub Pages</a>
      <span class="muted"> · </span>
      <a href="https://github.com/njueeRay/OpenProfile" target="_blank" rel="noopener">AI-Native workflow</a>
      <span class="muted"> · </span>
      <a href="/rss.xml" class="rss-link" target="_blank" rel="noopener" title="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: -2px;"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
        RSS
      </a>
    </div>
    <div class="line output muted">
      © {year} Ray Huang · MIT License
    </div>
    <div class="line cursor-line">
      <span class="prompt">❯</span>
      <span class="cursor">█</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 2.5rem 1.5rem 2rem;
    margin-top: 4rem;
  }

  .container {
    max-width: 780px;
    margin: 0 auto;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .line { display: flex; align-items: center; gap: 0.4rem; }

  .prompt { color: var(--color-green); }
  .cmd    { color: var(--color-text); }
  .output { padding-left: 1.4rem; color: var(--color-text-muted); }
  .muted  { color: var(--color-text-muted); }

  .cursor {
    display: inline-block;
    color: var(--color-accent);
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }

  a { color: var(--color-accent); text-decoration: none; }
  a:hover { color: #fff; }

  /* ─── Site Nav ─── */
  .footer-nav {
    display: flex;
    gap: 2.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .footer-nav-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .nav-group-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    opacity: 0.5;
    margin-bottom: 0.15rem;
  }

  .footer-nav-group a {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .footer-nav-group a:hover { color: var(--color-accent); }

  .footer-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: 1rem;
  }

  @media (max-width: 480px) {
    .footer-nav { gap: 1.5rem; }
  }
</style>
