---
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog');
const latestPost = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())[0];
---

<section class="hero">
  <div class="container">
    <div class="terminal-col">
    <div class="terminal-window">
      <div class="terminal-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
        <span class="terminal-title">~/njueeray — zsh</span>
      </div>
      <div class="terminal-body">
        <div class="line">
          <span class="prompt">❯</span>
          <span class="cmd"> whoami</span>
        </div>
        <div class="line output">
          <span class="name">Ray Huang</span>
          <span class="sep"> · </span>
          <span class="role">LLM Engineer</span>
          <span class="sep"> / </span>
          <span class="role">Open Source Programmer</span>
          <span class="sep"> / </span>
          <span class="role">Full-Stack Dev</span>
        </div>
        <div class="line space"></div>
        <div class="line">
          <span class="prompt">❯</span>
          <span class="cmd"> cat focus.txt</span>
        </div>
        <div class="line output">
          <span class="muted">Exploring the best AI-Native development practices.</span>
        </div>
        <div class="line space"></div>
        <div class="line">
          <span class="prompt">❯</span>
          <span class="cmd"> echo $STACK</span>
        </div>
        <div class="line output">
          <span class="tag">Python</span>
          <span class="tag">C++</span>
          <span class="tag">TypeScript</span>
          <span class="tag">JavaScript</span>
        </div>
        <div class="line space"></div>
        <div class="line">
          <span class="prompt">❯</span>
          <span class="cmd"> echo $MOTTO</span>
        </div>
        <div class="line output accent">
          "Future is coming, move early."
        </div>
        <div class="line space"></div>
        <div class="line cursor-line">
          <span class="prompt">❯</span>
          <span class="cursor">█</span>
        </div>
      </div>
    </div>

    <div class="hero-links">
      <a href="https://github.com/njueeRay" target="_blank" rel="noopener" class="btn">
        <svg height="16" viewBox="0 0 16 16" width="16" fill="currentColor" style="margin-right:6px"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        GitHub
      </a>
      <a href="https://github.com/njueeRay/OpenProfile" target="_blank" rel="noopener" class="btn btn-outline">
        How this was built →
      </a>
    </div>
    </div>{/* End .terminal-col */}

    <div class="narrative-col">
      <span class="identity-badge">✦ AI-native developer</span>
      <h1 class="narrative-headline">人类判断力<br/><span class="nh-accent">× AI 执行力</span></h1>
      <p class="narrative-desc">
        不是用 AI 生成代码，而是把 AI 当真正的工程师协同——<br class="desc-br"/>
        有角色、有边界、有记忆。
      </p>
      {latestPost && (
        <a href={`/blog/${latestPost.id}`} class="latest-post">
          <span class="lp-label">最新文章 →</span>
          <span class="lp-title">{latestPost.data.title}</span>
        </a>
      )}
      <div class="quick-stats">
        <div class="qs-item">
          <span class="qs-num">7</span>
          <span class="qs-label">AI Agents</span>
        </div>
        <div class="qs-item">
          <span class="qs-num">v5.10</span>
          <span class="qs-label">当前版本</span>
        </div>
        <div class="qs-item">
          <span class="qs-num">MIT</span>
          <span class="qs-label">开源协议</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 4rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }

  @media (min-width: 720px) {
    .container {
      display: grid;
      grid-template-columns: 58% 1fr;
      gap: 3rem;
      align-items: start;
    }
  }

  /* Terminal window */
  .terminal-window {
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    font-family: var(--font-mono);
    box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 24px 64px rgba(0,0,0,0.6);
  }

  .terminal-bar {
    background: var(--color-bg-3);
    padding: 0.7rem 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .dot {
    width: 12px; height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .terminal-title {
    margin-left: 0.6rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 1.6rem 2rem;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .line { display: flex; align-items: baseline; gap: 0.3rem; flex-wrap: wrap; }
  .line.space { height: 0.4rem; }
  .prompt { color: var(--color-accent); flex-shrink: 0; }
  .cmd { color: var(--color-text); }
  .output { padding-left: 1.6rem; }

  .name { color: #fff; font-weight: 700; font-size: 1.05rem; }
  .sep  { color: var(--color-border); }
  .role { color: var(--color-text-muted); font-size: 0.9rem; }
  .muted { color: var(--color-text-muted); }
  .accent { color: var(--color-accent); font-style: italic; }

  /* Stack tags */
  .tag {
    font-size: 0.75rem;
    background: rgba(0,180,216,0.1);
    border: 1px solid rgba(0,180,216,0.25);
    border-radius: 4px;
    padding: 0.1rem 0.55rem;
    color: var(--color-accent);
  }

  /* Blinking cursor */
  .cursor {
    color: var(--color-accent);
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* CTA buttons */
  .hero-links {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.5rem;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    background: var(--color-accent);
    color: var(--color-bg);
    font-weight: 600;
    transition: opacity 0.2s, transform 0.15s;
  }
  .btn:hover { opacity: 0.88; color: var(--color-bg); transform: translateY(-1px); }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(0,180,216,0.06);
  }

  /* ── Terminal typewriter reveal ─────────────── */
  @keyframes term-reveal {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .terminal-body .line {
    opacity: 0;
    animation: term-reveal 0.18s ease forwards;
  }
  /* Skip animation when user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .terminal-body .line { opacity: 1; animation: none; }
  }

  /* CTA buttons also reveal after terminal */
  .hero-links {
    opacity: 0;
    animation: term-reveal 0.25s ease forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-links { opacity: 1; animation: none; }
  }

  /* ── Narrative column ────────────────────── */
  .narrative-col {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    padding-top: 0.5rem;
  }

  .identity-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: rgba(88, 166, 255, 0.08);
    border: 1px solid rgba(88, 166, 255, 0.2);
    border-radius: 20px;
    padding: 0.25rem 0.85rem;
    width: fit-content;
  }

  .narrative-headline {
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0;
  }
  .nh-accent { color: var(--color-accent); }

  .narrative-desc {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
    margin: 0;
  }
  .desc-br { display: none; }
  @media (min-width: 720px) { .desc-br { display: inline; } }

  .latest-post {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.9rem 1.1rem;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    transition: border-color 0.2s, background 0.2s;
    text-decoration: none;
  }
  .latest-post:hover {
    border-color: var(--color-accent);
    background: var(--color-bg-3);
  }
  .lp-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .lp-title {
    font-size: 0.88rem;
    color: var(--color-text);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .quick-stats {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .qs-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 3.5rem;
  }
  .qs-num {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1;
  }
  .qs-label {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
  }
</style>

<script>
  function initHeroTyping() {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReduced) return;

    const body = document.querySelector<HTMLElement>('.terminal-body');
    const heroLinks = document.querySelector<HTMLElement>('.hero-links');
    if (!body) return;

    const lines = body.querySelectorAll<HTMLElement>('.line');
    // Base delay: start after nav settles (300ms), each line ~200ms apart
    const BASE = 0.3;
    const STEP = 0.2;
    lines.forEach((line, i) => {
      line.style.animationDelay = `${BASE + i * STEP}s`;
    });

    // Reveal hero links after all lines
    if (heroLinks) {
      heroLinks.style.animationDelay = `${BASE + lines.length * STEP + 0.1}s`;
    }
  }

  document.addEventListener('astro:page-load', initHeroTyping);
  initHeroTyping();
</script>
